# Optional compose shell defaults. Uncomment only when you need to override
# the repo-documented baseline or enable the production override.
# Controls the Compose project name and volume/container prefix.
# COMPOSE_PROJECT_NAME=weclaws
# Production bind-mount root used only by docker-compose.prod.yml.
# Uncomment when deploying with the production override.
# WECLAWS_DATA_ROOT=/srv/weclaws/data
# Example production override:
# WECLAWS_DATA_ROOT=/srv/weclaws/data
# APP_BASE_URL=https://weclaws.example.com
# WEB_PORT=3000
# Controls the exposed web host port. Keep APP_BASE_URL in sync if changed.
# WEB_PORT=3000

# Required for any web deployment.
APP_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-me
BROWSERLESS_TOKEN=replace-me

# Optional admin/bootstrap behavior. Uncomment only when needed.
# Optional admin whitelist used for bootstrap/admin access.
# Supported forms:
# - empty
# - one email: admin@example.com
# - multiple emails: admin@example.com,ops@example.com
# WEB_ADMIN_EMAILS=admin@example.com
# Optional per-user bot creation hard limit.
# - empty or 0: unlimited
# - positive integer: max bots each user can create
# WEB_USER_BOT_LIMIT=0

# Optional supervisor runtime overrides. The base compose file already provides
# these defaults.
# Allowed values:
# - remote: supervisor injects each user's sandbox-runtime pool URL/key into FastAgent child
# - disabled: supervisor runs FastAgent without sandbox args
# FASTAGENT_SANDBOX_MODE=remote
# RECONCILE_INTERVAL_MS=2000

# Optional repo-local sandbox image/runtime overrides. Leave
# SANDBOX_RUNTIME_NPM_VERSION unset to use infra/docker/sandbox-runtime.versions.env.
# SANDBOX_RUNTIME_NPM_VERSION=
# AGENT_BROWSER_NPM_VERSION=0.27.0
# BUN_VERSION=1.3.13
# LARK_CLI_NPM_VERSION=1.0.32
# PNPM_VERSION=9.15.4
# UV_VERSION=0.11.7
# SANDBOX_RUNTIME_PORT=8788
# SANDBOX_RUNTIME_LOG_LEVEL=info

# Optional Browserless sidecar overrides. The browserless service stays on the
# internal Compose network by default. Expose a host port only via a local
# override file when you need debugging or external clients.
# BROWSERLESS_API_URL=http://browserless:3000
# BROWSERLESS_CONCURRENT=2
# BROWSERLESS_QUEUED=2
# BROWSERLESS_TIMEOUT=120000

# Optional per-user sandbox-runtime pool defaults. These values are consumed by
# web during registration and by supervisor during pool provisioning.
# SRT_DEFAULT_POOL_SIZE=3
# SRT_DEFAULT_MIN_READY_PROCESSES=1
# SRT_DEFAULT_SESSION_TIMEOUT_MS=600000
# SRT_DEFAULT_MAX_CONCURRENT_INIT=1
# SRT_DEFAULT_HEALTH_CHECK_INTERVAL_MS=60000
# SRT_DEFAULT_PORT_RANGE_WIDTH=100
# SRT_PORT_BASE=31000
# SRT_PROXY_PORT_BASE=9100
# SRT_WORKSPACE_BASE_ROOT=/app/apps/sandbox-runtime/user-workspaces

# Optional per-user sandbox policy overrides. Uncomment only when you need to
# tighten or expand the default filesystem/network policy.
# Comma-separated domain denylist. Empty means outbound access uses the
# upstream allow-by-default policy.
# Supported forms:
# - empty
# - one domain
# - multiple domains: a.com,b.com,*.example.com
# SRT_DEFAULT_DENIED_DOMAINS=
# Comma-separated path lists. Supported forms:
# - empty
# - one path
# - multiple paths separated by commas
# SRT_DEFAULT_ALLOW_READ=
# SRT_DEFAULT_ALLOW_WRITE=/tmp
# SRT_DEFAULT_DENY_READ=/etc/passwd,/etc/passwd-,/etc/shadow,/etc/shadow-,/etc/group,/etc/group-,/etc/gshadow,/etc/gshadow-,/etc/mtab,/proc/self/mountinfo,/proc/*/mountinfo,/proc/self/mounts,/proc/*/mounts,/proc/mounts,/proc/self/mountstats,/proc/*/mountstats,/proc/self/cmdline,/proc/1/cmdline,/proc/*/cmdline,/proc/self/environ,/proc/1/environ,/proc/*/environ,/proc/kallsyms,/proc/self/cgroup,/proc/*/cgroup,/proc/cgroups,/root,~/.ssh,~/.aws
# SRT_DEFAULT_DENY_WRITE=.env,~/.ssh,~/.aws
