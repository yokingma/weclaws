{
  "name": "@weclaws/db",
  "version": "0.2.6",
  "private": true,
  "type": "module",
  "dependencies": {
    "@weclaws/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.31.10"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "test": "pnpm exec vitest --run",
    "typecheck": "pnpm exec tsc -p tsconfig.json",
    "db:generate": "pnpm exec drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "pnpm exec drizzle-kit migrate --config=drizzle.config.ts"
  }
}
